rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Business-scoped file access
    // Path: /businesses/{businessId}/{allPaths=**}
    match /businesses/{businessId}/{allPaths=**} {
      allow read: if request.auth != null &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.businessId == businessId &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['owner', 'manager'];
    }

    // User avatar files (legacy path)
    // Path: /users/{userId}/{allPaths=**}
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

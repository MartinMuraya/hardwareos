rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // HELPER FUNCTIONS
    // =========================================================

    // Is the caller authenticated?
    function isAuth() {
      return request.auth != null;
    }

    // Get calling user's profile doc
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Does caller belong to this business?
    function isMember(businessId) {
      return isAuth() && userDoc().businessId == businessId;
    }

    // Is caller the owner of this business?
    function isOwner(businessId) {
      return isMember(businessId) && userDoc().role == 'owner';
    }

    // Is caller owner or manager?
    function isManager(businessId) {
      return isMember(businessId) &&
        (userDoc().role == 'owner' || userDoc().role == 'manager');
    }

    // =========================================================
    // BUSINESSES
    // Members can read their own business doc.
    // Only Cloud Functions (Admin SDK) can write.
    // =========================================================
    match /businesses/{businessId} {
      allow read: if isMember(businessId);
      allow write: if false; // All writes via Cloud Functions only
    }

    // =========================================================
    // USERS
    // A user can read their own profile.
    // Owner can read all users in their business.
    // All writes via Cloud Functions only.
    // =========================================================
    match /users/{uid} {
      allow read: if isAuth() && (
        request.auth.uid == uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         userDoc().businessId == resource.data.businessId &&
         userDoc().role == 'owner')
      );
      allow write: if false; // All writes via Cloud Functions only
    }

    // =========================================================
    // PRODUCTS
    // Members can read. Only owner/manager can write directly
    // (but in practice all writes go through Cloud Functions).
    // =========================================================
    match /products/{productId} {
      allow read: if isAuth() &&
        isMember(resource.data.businessId);

      // Deny direct client writes — all mutations via Cloud Functions
      allow create, update, delete: if false;
    }

    // =========================================================
    // SALES
    // All members can read. No direct client writes.
    // =========================================================
    match /sales/{saleId} {
      allow read: if isAuth() &&
        isMember(resource.data.businessId);
      allow create, update, delete: if false;
    }

    // =========================================================
    // EXPENSES
    // Owner/Manager can read. No direct client writes.
    // =========================================================
    match /expenses/{expenseId} {
      allow read: if isAuth() &&
        isManager(resource.data.businessId);
      allow create, update, delete: if false;
    }

    // =========================================================
    // PURCHASES
    // Owner/Manager can read. No direct client writes.
    // =========================================================
    match /purchases/{purchaseId} {
      allow read: if isAuth() &&
        isManager(resource.data.businessId);
      allow create, update, delete: if false;
    }

    // =========================================================
    // STOCK MOVEMENTS
    // All members can read (for transparency). No direct writes.
    // =========================================================
    match /stockMovements/{movementId} {
      allow read: if isAuth() &&
        isMember(resource.data.businessId);
      allow create, update, delete: if false;
    }

    // =========================================================
    // PLANS
    // Public read (all users can view plans). No direct client writes.
    // =========================================================
    match /plans/{planId} {
      allow read: if true; // Plans are public
      allow create, update, delete: if false; // All writes via Cloud Functions only
    }

    // =========================================================
    // SUBSCRIPTIONS
    // Business owner can read their own subscriptions.
    // Super Admin can read all subscriptions.
    // No direct client writes.
    // =========================================================
    match /subscriptions/{subscriptionId} {
      allow read: if isAuth() && (
        userDoc().isSuperAdmin == true ||
        resource.data.businessId == userDoc().businessId
      );
      allow create, update, delete: if false; // All writes via Cloud Functions only
    }

    // =========================================================
    // SYSTEM NOTIFICATIONS
    // Business owner can read their own notifications.
    // Super Admin can read all notifications.
    // No direct client writes.
    // =========================================================
    match /systemNotifications/{notificationId} {
      allow read: if isAuth() && (
        userDoc().isSuperAdmin == true ||
        resource.data.businessId == userDoc().businessId
      );
      allow create, update, delete: if false; // All writes via Cloud Functions only
    }

    // =========================================================
    // AUDIT LOGS
    // Only Super Admin can read.
    // No direct client writes.
    // =========================================================
    match /auditLogs/{logId} {
      allow read: if isAuth() && userDoc().isSuperAdmin == true;
      allow create, update, delete: if false; // All writes via Cloud Functions only
    }

    // =========================================================
    // Cash Drawer — read-only via rules; writes via Cloud Functions
    // =========================================================
    match /cashSessions/{sessionId} {
      allow read: if isMember(resource.data.businessId);
      allow create, update, delete: if false;
    }

    // =========================================================
    // Branches — read-only via rules; writes via Cloud Functions
    // =========================================================
    match /branches/{branchId} {
      allow read: if isMember(resource.data.businessId);
      allow create, update, delete: if false;
    }

    // =========================================================
    // Stock Transfers — read-only via rules; writes via Cloud Functions
    // =========================================================
    match /stockTransfers/{transferId} {
      allow read: if isMember(resource.data.businessId);
      allow create, update, delete: if false;
    }

    // =========================================================
    // Notification Queue — read-only via rules; writes via Cloud Functions
    // =========================================================
    match /notificationQueue/{notificationId} {
      allow read: if isMember(resource.data.businessId);
      allow create, update, delete: if false;
    }

    // =========================================================
    // DEFAULT DENY — reject everything else
    // =========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
